lt Music;","/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/data.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Song.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Player.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Gallery.js",["154","155"],"import React, { useState } from 'react'\n\nimport myGallery from \"../dataPictures\";\nimport Picture from \"./Picture\";\nimport instagram from \"../img/social/instagram.svg\"\n\n\nconst Gallery = () => {\n    const [pics, setPics] = useState(myGallery);\n\n    return (\n        <div className=\"gallery-wrapper\">\n            <div className=\"gallery container\">\n                <h1 className=\"gallery-title\">Gallery</h1>\n                <div className=\"gallery-container\">\n                    {pics.map((img) => (\n                        <Picture img={img.img} name={img.name} key={img.id}></Picture>\n                    ))}\n                </div>\n                <div className=\"follow-me-ig\">\n                    <img src={instagram} />\n                    <p>Follow me @jagsymusic for more</p>\n                </div>\n            </div>\n        </div>\n    )\n}\n\nexport default Gallery","/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/dataPictures.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Picture.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Contact.js",["156"],"import React from 'react'\n\nimport Socials from \"./Socials\";\n\nconst Contact = () => {\n    return (\n        <div className=\"contact-wrapper\">\n            <div className=\"container\">\n                <h1 className=\"contact-title\">Contact me</h1>\n                <div className=\"contacts\">\n                    <div className=\"contact-general\">\n                        <h1>General</h1>\n                        <p>contact@jagsymusic.com</p>\n                    </div>\n                    <div className=\"contact-demos\">\n                        <h1>Demos</h1>\n                        <p>demos@jagsymusic.com</p>\n                    </div>\n                </div>\n                \n                {/*<Socials pos=\"contact-socials\"/>*/}\n            </div>\n        </div>\n    )\n}\n\nexport default Contact\n","/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Socials.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Footer.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/index.js",[],["157","158"],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/reportWebVitals.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/App.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/pages/HomePage.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/components/Gallery.js",["159"],"import React, { useState } from \"react\";\n\nimport myGallery from \"../dataPictures\";\nimport Picture from \"./Picture\";\nimport instagram from \"../img/social/instagram.svg\"\nimport {useScroll} from \"../utils/useScroll\";\nimport {scrollAnim} from \"../animation\";\nimport {motion} from \"framer-motion\";\n\n\nconst Gallery = () => {\n    const [pics, setPics] = useState(myGallery);\n    const [element, controls] = useScroll();\n\n    return (\n        <div className=\"gallery-wrapper\">\n            <motion.div className=\"gallery container\"\n            ref={element} animate={controls} initial=\"hidden\" variants={scrollAnim}>\n                <h1 className=\"gallery-title\">Gallery</h1>\n                <div className=\"gallery-container\">\n                    {pics.map((img) => (\n                        <Picture img={img.img} name={img.name} key={img.id}/>\n                    ))}\n                </div>\n                <div className=\"follow-wrapper\">\n                    <a href=\"http://instagram.com/jagsymusic\">\n                        <div className=\"follow-me-ig\">\n                            <img src={instagram}  alt=\"instagram\"/>\n                            <p>Follow me @jagsymusic for more</p>\n                        </div>\n                    </a>\n                </div>\n            </motion.div>\n        </div>\n  );\n};\n\nexport default Gallery;\n","/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/components/Header.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/components/Music.js",["160"],"import React, {useState} from \"react\";\nimport {motion} from \"framer-motion\";\nimport myTracks from \"../data\";\nimport Song from \"./Song\";\nimport {useScroll} from \"../utils/useScroll\";\nimport {scrollAnim} from \"../animation\";\n\nconst Music = () => {\n    const [songs, setSongs] = useState(myTracks());\n    const [element, controls] = useScroll();\n\n    return(\n        <div className=\"music-wrapper\">\n            <motion.div className=\"music-container container\"\n            ref={element} animate={controls} initial=\"hidden\" variants={scrollAnim}>\n                <p className=\"music-title\">CHECK OUT MY MUSIC</p>\n                <div className=\"songs\">\n                    {songs.map(s => <Song song={s} key={s.id} />)}\n                </div>\n            </motion.div>\n        </div>\n  );\n};\n\nexport default Music;\n","/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/components/Player.js",[],["161","162"],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/components/Contact.js",["163"],"import React from 'react'\nimport {motion} from \"framer-motion\";\nimport Socials fr