.map(s => <Song song={s} key={s.id} />)}\n                </div>\n            </div>\n        </div>\n    )\n}\n\nexport default Music;","/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/data.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Song.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Player.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Gallery.js",["73","74"],"import React, { useState } from 'react'\n\nimport myGallery from \"../dataPictures\";\nimport Picture from \"./Picture\";\nimport instagram from \"../img/social/instagram.svg\"\n\n\nconst Gallery = () => {\n    const [pics, setPics] = useState(myGallery);\n\n    return (\n        <div className=\"gallery-wrapper\">\n            <div className=\"gallery container\">\n                <h1 className=\"gallery-title\">Gallery</h1>\n                <div className=\"gallery-container\">\n                    {pics.map((img) => (\n                        <Picture img={img.img} name={img.name} key={img.id}></Picture>\n                    ))}\n                </div>\n                <div className=\"follow-me-ig\">\n                    <img src={instagram} />\n                    <p>Follow me @jagsymusic for more</p>\n                </div>\n            </div>\n        </div>\n    )\n}\n\nexport default Gallery","/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/dataPictures.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Picture.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Contact.js",["75"],"import React from 'react'\n\nimport Socials from \"./Socials\";\n\nconst Contact = () => {\n    return (\n        <div className=\"contact-wrapper\">\n            <div className=\"container\">\n                <h1 className=\"contact-title\">Contact me</h1>\n                <div className=\"contacts\">\n                    <div className=\"contact-general\">\n                        <h1>General</h1>\n                        <p>contact@jagsymusic.com</p>\n                    </div>\n                    <div className=\"contact-demos\">\n                        <h1>Demos</h1>\n                        <p>demos@jagsymusic.com</p>\n                    </div>\n                </div>\n                \n                {/*<Socials pos=\"contact-socials\"/>*/}\n            </div>\n        </div>\n    )\n}\n\nexport default Contact\n","/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Socials.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Footer.js",[],{"ruleId":"76","replacedBy":"77"},{"ruleId":"78","replacedBy":"79"},{"ruleId":"80","severity":1,"message":"81","line":9,"column":19,"nodeType":"82","messageId":"83","endLine":9,"endColumn":27},{"ruleId":"80","severity":1,"message":"84","line":9,"column":18,"nodeType":"82","messageId":"83","endLine":9,"endColumn":25},{"ruleId":"85","severity":1,"message":"86","line":21,"column":21,"nodeType":"87","endLine":21,"endColumn":44},{"ruleId":"80","severity":1,"message":"88","line":3,"column":8,"nodeType":"82","messageId":"83","endLine":3,"endColumn":15},"no-native-reassign",["89"],"no-negated-in-lhs",["90"],"no-unused-vars","'setSongs' is assigned a value but never used.","Identifier","unusedVar","'setPics' is assigned a value but never used.","jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement","'Socials' is defined but never used.","no-global-assign","no-unsafe-negation"]