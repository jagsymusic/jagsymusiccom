rorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"106"},"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/index.js",[],["138","139"],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/App.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/reportWebVitals.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Nav.js",[],["140","141"],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Header.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/pages/HomePage.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Music.js",["142"],"import React, {useState} from \"react\";\n//data\nimport myTracks from \"../data\";\n//components\nimport Song from \"./Song\";\n\nconst Music = () => {\n\n    const [songs, setSongs] = useState(myTracks());\n\n    return(\n        <div className=\"music-wrapper\">\n            <div className=\"music-container container\">\n                <p className=\"music-title\">CHECK OUT MY MUSIC</p>\n                <div className=\"songs\">\n                    {songs.map(s => <Song song={s} key={s.id} />)}\n                </div>\n            </div>\n        </div>\n    )\n}\n\nexport default Music;","/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/data.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Song.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Player.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Gallery.js",["143","144"],"import React, { useState } from 'react'\n\nimport myGallery from \"../dataPictures\";\nimport Picture from \"./Picture\";\nimport instagram from \"../img/social/instagram.svg\"\n\n\nconst Gallery = () => {\n    const [pics, setPics] = useState(myGallery);\n\n    return (\n        <div className=\"gallery-wrapper\">\n            <div className=\"gallery container\">\n                <h1 className=\"gallery-title\">Gallery</h1>\n                <div className=\"gallery-container\">\n                    {pics.map((img) => (\n                        <Picture img={img.img} name={img.name} key={img.id}></Picture>\n                    ))}\n                </div>\n                <div className=\"follow-me-ig\">\n                    <img src={instagram} />\n                    <p>Follow me @jagsymusic for more</p>\n                </div>\n            </div>\n        </div>\n    )\n}\n\nexport default Gallery","/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/dataPictures.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Picture.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Contact.js",["145"],"import React from 'react'\n\nimport Socials from \"./Socials\";\n\nconst Contact = () => {\n    return (\n        <div className=\"contact-wrapper\">\n            <div className=\"container\">\n                <h1 className=\"contact-title\">Contact me</h1>\n                <div className=\"contacts\">\n                    <div className=\"contact-general\">\n                        <h1>General</h1>\n                        <p>contact@jagsymusic.com</p>\n                    </div>\n                    <div className=\"contact-demos\">\n                        <h1>Demos</h1>\n                        <p>demos@jagsymusic.com</p>\n                    </div>\n                </div>\n                \n                {/*<Socials pos=\"contact-socials\"/>*/}\n            </div>\n        </div>\n    )\n}\n\nexport default Contact\n","/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Socials.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/dev/jagsyweb/src/components/Footer.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/index.js",[],["146","147"],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/reportWebVitals.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/App.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/pages/HomePage.js",["148"],"import React from \"react\";\nimport Gallery from \"../components/Gallery\";\n//components\nimport Header from \"../components/Header\";\nimport Music from \"../components/Music\";\nimport Player from \"../components/Player\";\nimport Contact from \"../components/Contact\";\nimport Footer from \"../components/Footer\";\n\nconst HomePage = () => {\n    return (\n        <div>\n            <Header/>\n            <Music/>\n            <Gallery />\n            <Contact />\n            <Footer />\n        </div>\n    )\n}\n\nexport default HomePage;","/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/components/Gallery.js",["149"],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/components/Header.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/components/Music.js",["150"],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/components/Player.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/components/Contact.js",["151"],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/components/Footer.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/components/Picture.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/dataPictures.js",[],"/Users/magnus/Documents/PersonalProjects/jagsywebbbb/jagsymusiccom/jagsymusiccom/src/data.js",[],"/Users/magnus/Document